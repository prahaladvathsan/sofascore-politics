---
import IndiaMap from "../components/Map/IndiaMap.tsx";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCandidate, getParty, listConstituenciesByState } from "../lib/data";

const baseUrl = import.meta.env.BASE_URL;
const cards = listConstituenciesByState("TN").map((constituency) => ({
  constituency,
  candidate: getCandidate(constituency.current_mla_id),
  party: getParty(constituency.current_party_id),
}));
---

<BaseLayout
  title="Political Report Card | India Election Transparency"
  description="A static, map-first transparency prototype for Indian state elections."
>
  <section
    class="mx-auto grid max-w-6xl gap-8 px-4 py-10 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:px-8 lg:py-14"
  >
    <div class="space-y-6">
      <div
        class="inline-flex items-center rounded-full border border-brand-saffron/20 bg-white/70 px-3 py-1 text-sm text-brand-saffron"
      >
        Phase 1 hello-world deploy
      </div>
      <div class="space-y-4">
        <h1
          class="max-w-xl text-4xl font-semibold tracking-tight text-brand-ink sm:text-5xl"
        >
          Map-first political transparency, seeded for Tamil Nadu.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-brand-slate">
          This prototype keeps every public record as static JSON, ships through
          GitHub Pages, and leaves LLM-backed work inside offline pipelines
          rather than the request path.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        <article
          class="rounded-3xl border border-brand-ink/10 bg-white/85 p-5 shadow-card"
        >
          <p class="text-sm uppercase tracking-[0.2em] text-brand-saffron">
            Seeded scope
          </p>
          <p class="mt-3 text-3xl font-semibold text-brand-ink">
            {cards.length}
          </p>
          <p class="mt-2 text-sm text-brand-slate">
            Tamil Nadu constituencies with incumbent MLA cards in this phase.
          </p>
        </article>
        <article
          class="rounded-3xl border border-brand-ink/10 bg-white/85 p-5 shadow-card"
        >
          <p class="text-sm uppercase tracking-[0.2em] text-brand-leaf">
            Static data
          </p>
          <p class="mt-3 text-3xl font-semibold text-brand-ink">100%</p>
          <p class="mt-2 text-sm text-brand-slate">
            No backend, database, or request-time AI calls.
          </p>
        </article>
      </div>
      <div class="flex flex-wrap gap-3">
        <a
          href={`${baseUrl}state/TN`}
          class="rounded-full bg-brand-ink px-5 py-3 text-sm font-medium text-white transition hover:bg-brand-ink/90"
        >
          Explore Tamil Nadu
        </a>
        <a
          href={`${baseUrl}constituency/TN-177`}
          class="rounded-full border border-brand-ink/15 bg-white/80 px-5 py-3 text-sm font-medium text-brand-ink transition hover:border-brand-ink/30"
        >
          Open Peravurani card
        </a>
      </div>
    </div>
    <IndiaMap client:load />
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-14 sm:px-6 lg:px-8">
    <div class="mb-6 flex items-end justify-between gap-4">
      <div>
        <p class="text-sm uppercase tracking-[0.2em] text-brand-saffron">
          Seed data
        </p>
        <h2 class="mt-2 text-2xl font-semibold text-brand-ink">
          Tamil Nadu hello-world cards
        </h2>
      </div>
      <p class="max-w-md text-sm text-brand-slate">
        Constituency numbering is cross-checked against the official ECI 2021
        PDF and incumbent context is frozen to the pre-May-4, 2026 snapshot for
        this scaffold.
      </p>
    </div>
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {
        cards.map(({ constituency, candidate, party }) => (
          <a
            href={`${baseUrl}constituency/${constituency.id}`}
            class="rounded-3xl border border-brand-ink/10 bg-white/85 p-5 shadow-card transition hover:-translate-y-0.5 hover:border-brand-saffron/30"
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-sm uppercase tracking-[0.18em] text-brand-saffron">
                  Seat {constituency.number}
                </p>
                <h3 class="mt-2 text-xl font-semibold text-brand-ink">
                  {constituency.name}
                </h3>
              </div>
              <span
                class="rounded-full px-3 py-1 text-xs font-medium text-white"
                style={`background:${party.color};`}
              >
                {party.short_name}
              </span>
            </div>
            <p class="mt-4 text-sm text-brand-slate">{constituency.summary}</p>
            <dl class="mt-5 grid gap-2 text-sm text-brand-slate">
              <div class="flex justify-between gap-3">
                <dt>District</dt>
                <dd class="font-medium text-brand-ink">
                  {constituency.district}
                </dd>
              </div>
              <div class="flex justify-between gap-3">
                <dt>Current MLA</dt>
                <dd class="text-right font-medium text-brand-ink">
                  {candidate.name}
                </dd>
              </div>
            </dl>
          </a>
        ))
      }
    </div>
    <div
      class="mt-8 rounded-3xl border border-dashed border-brand-ink/15 bg-white/60 p-5 text-sm text-brand-slate"
    >
      The underlying JSON files are served statically from <code>/data</code>,
      including schemas under
      <code>/data/schemas</code> for future pipeline validation.
    </div>
  </section>
</BaseLayout>
