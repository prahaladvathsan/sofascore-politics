---
import NationalChoropleth from "../components/Map/NationalChoropleth.tsx";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  listConstituenciesByState,
  listStateElectionStatuses,
} from "../lib/data";
import { toStatePath, withBase } from "../lib/routing";
import { buildNationalStateSummaries } from "../lib/view-models";

const baseUrl = import.meta.env.BASE_URL;
const stateSummaries = buildNationalStateSummaries(baseUrl);
const scheduledStates = stateSummaries.filter(
  (state) => state.scheduleStatus === "officially_announced",
);
const seededTamilNaduSeats = listConstituenciesByState("TN");
const assemblyStateCount = stateSummaries.filter(
  (state) => state.hasAssembly,
).length;
const scheduledCount = listStateElectionStatuses().length;
---

<BaseLayout
  title="Political Report Card | India Election Transparency"
  description="Static national-to-seat election navigation for Indian state assemblies."
>
  <section
    class="mx-auto grid max-w-6xl gap-8 px-4 py-10 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:px-8 lg:py-14"
  >
    <div class="space-y-6">
      <p class="eyebrow">Core navigation MVP</p>
      <div class="space-y-4">
        <h1
          class="max-w-3xl text-5xl tracking-tight sm:text-6xl"
          tabindex="-1"
          data-route-heading="true"
          style="view-transition-name:national-heading"
        >
          National heatmap to constituency panel, without a backend in sight.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-page-muted">
          The homepage loads only the national map bundle, colors states by the
          months remaining until an officially announced ECI poll date, and
          falls back to an accessible list view whenever geometry fails.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-3">
        <article class="metric-card">
          <p class="eyebrow">Assembly routes</p>
          <p class="mt-3 text-3xl font-semibold">{assemblyStateCount}</p>
          <p class="metric-copy">
            State pages are live for every assembly-bearing state or territory.
          </p>
        </article>
        <article class="metric-card">
          <p class="eyebrow">Official schedules</p>
          <p class="mt-3 text-3xl font-semibold">{scheduledCount}</p>
          <p class="metric-copy">
            States with an officially announced ECI calendar are colored with
            viridis.
          </p>
        </article>
        <article class="metric-card">
          <p class="eyebrow">Seeded seats</p>
          <p class="mt-3 text-3xl font-semibold">
            {seededTamilNaduSeats.length}
          </p>
          <p class="metric-copy">
            Tamil Nadu incumbent cards are carried forward as the first overlay
            layer.
          </p>
        </article>
      </div>
    </div>
    <div class="editorial-panel">
      <p class="eyebrow">Today's live routes</p>
      <h2 class="panel-title">Where the MVP goes deepest</h2>
      <div class="mt-5 grid gap-3">
        {
          [
            {
              name: "Tamil Nadu map view",
              copy: "Constituency polygons, seeded MLA overlays, and a canonical lowercase route.",
              href: withBase(baseUrl, toStatePath("TN")),
            },
            {
              name: "West Bengal map view",
              copy: "Geometry-backed navigation now lives alongside a sparse candidate state.",
              href: withBase(baseUrl, toStatePath("WB")),
            },
          ].map((item) => (
            <a href={item.href} class="shell-card block">
              <p class="font-semibold">{item.name}</p>
              <p class="shell-copy">{item.copy}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-14 sm:px-6 lg:px-8">
    <NationalChoropleth
      client:load
      geometryPath={`${baseUrl}data/geo/optimized/india-states.topojson`}
      states={stateSummaries}
    />
  </section>

  <section
    class="mx-auto grid max-w-6xl gap-6 px-4 pb-14 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:px-8"
  >
    <div class="editorial-panel">
      <p class="eyebrow">Officially scheduled</p>
      <h2 class="panel-title">States with an ECI-announced calendar</h2>
      <div class="mt-5 grid gap-3">
        {
          scheduledStates.map((state) => (
            <a href={state.href} class="shell-card block">
              <p class="font-semibold">{state.name}</p>
              <p class="shell-copy">{state.statusLabel}</p>
            </a>
          ))
        }
      </div>
    </div>

    <div class="editorial-panel">
      <p class="eyebrow">Seed overlay</p>
      <h2 class="panel-title">Tamil Nadu seats already enriched</h2>
      <div class="mt-5 grid gap-3">
        {
          seededTamilNaduSeats.map((seat) => (
            <a
              href={`${baseUrl}constituency/${seat.id.toLowerCase()}`}
              class="shell-card block"
            >
              <p class="font-semibold">
                Seat {seat.number}: {seat.name}
              </p>
              <p class="shell-copy">{seat.summary}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
