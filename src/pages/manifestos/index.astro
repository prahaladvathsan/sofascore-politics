---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Manifestos | Political Report Card"
  description="Reserved manifesto tracker route for later phases."
>
  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
    <div
      class="rounded-[2rem] border border-dashed border-brand-ink/15 bg-white/80 p-8 text-brand-slate shadow-card"
    >
      <p class="text-sm uppercase tracking-[0.18em] text-brand-saffron">
        Reserved route
      </p>
      <h1 class="mt-3 text-3xl font-semibold text-brand-ink">
        Manifesto tracking is intentionally out of scope here.
      </h1>
      <p class="mt-3">
        Phase 1 only establishes the route shell and JSON schema contract so
        later work can add a tracker without changing the site architecture.
      </p>
    </div>
  </section>
</BaseLayout>
