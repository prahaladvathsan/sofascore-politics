---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getCandidate,
  getParty,
  getState,
  listConstituenciesByState,
  listStateCodes,
} from "../../lib/data";

export function getStaticPaths() {
  return listStateCodes().map((code) => ({
    params: { code },
  }));
}

const baseUrl = import.meta.env.BASE_URL;
const code = Astro.params.code ?? "TN";
const state = getState(code);
const constituencies = listConstituenciesByState(code).map((constituency) => ({
  constituency,
  candidate: getCandidate(constituency.current_mla_id),
  party: getParty(constituency.current_party_id),
}));
---

<BaseLayout
  title={`${state.name} | Political Report Card`}
  description={`Seed constituency cards for ${state.name}.`}
>
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
      <div
        class="rounded-[2rem] border border-brand-ink/10 bg-white/80 p-6 shadow-card"
      >
        <p class="text-sm uppercase tracking-[0.2em] text-brand-saffron">
          State drilldown
        </p>
        <h1 class="mt-3 text-4xl font-semibold text-brand-ink">{state.name}</h1>
        <p class="mt-4 text-brand-slate">
          Phase 1 seeds {state.seed_constituency_ids.length} constituencies out of
          {state.assembly_seats_total} total assembly seats.
        </p>
        <dl class="mt-6 grid gap-3 text-sm text-brand-slate">
          <div
            class="flex items-center justify-between gap-3 rounded-2xl bg-brand-sand/70 px-4 py-3"
          >
            <dt>Code</dt>
            <dd class="font-medium text-brand-ink">{state.code}</dd>
          </div>
          <div
            class="flex items-center justify-between gap-3 rounded-2xl bg-brand-sand/70 px-4 py-3"
          >
            <dt>Seeded seats</dt>
            <dd class="font-medium text-brand-ink">
              {state.seed_constituency_ids.length}
            </dd>
          </div>
          <div
            class="flex items-center justify-between gap-3 rounded-2xl bg-brand-sand/70 px-4 py-3"
          >
            <dt>Storage model</dt>
            <dd class="font-medium text-brand-ink">Static JSON only</dd>
          </div>
        </dl>
      </div>

      <div class="space-y-4">
        {
          constituencies.map(({ constituency, candidate, party }) => (
            <article class="rounded-[2rem] border border-brand-ink/10 bg-white/85 p-6 shadow-card">
              <div class="flex flex-wrap items-start justify-between gap-4">
                <div>
                  <p class="text-sm uppercase tracking-[0.18em] text-brand-saffron">
                    Seat {constituency.number}
                  </p>
                  <h2 class="mt-2 text-2xl font-semibold text-brand-ink">
                    {constituency.name}
                  </h2>
                  <p class="mt-2 text-brand-slate">{constituency.summary}</p>
                </div>
                <span
                  class="rounded-full px-3 py-1 text-xs font-medium text-white"
                  style={`background:${party.color};`}
                >
                  {party.short_name}
                </span>
              </div>
              <dl class="mt-5 grid gap-3 text-sm text-brand-slate sm:grid-cols-3">
                <div class="rounded-2xl bg-brand-sand/70 px-4 py-3">
                  <dt>District</dt>
                  <dd class="mt-1 font-medium text-brand-ink">
                    {constituency.district}
                  </dd>
                </div>
                <div class="rounded-2xl bg-brand-sand/70 px-4 py-3">
                  <dt>Reservation</dt>
                  <dd class="mt-1 font-medium text-brand-ink">
                    {constituency.reservation}
                  </dd>
                </div>
                <div class="rounded-2xl bg-brand-sand/70 px-4 py-3">
                  <dt>Current MLA</dt>
                  <dd class="mt-1 font-medium text-brand-ink">
                    {candidate.name}
                  </dd>
                </div>
              </dl>
              <a
                href={`${baseUrl}constituency/${constituency.id}`}
                class="mt-5 inline-flex rounded-full border border-brand-ink/15 bg-white px-4 py-2 text-sm font-medium text-brand-ink transition hover:border-brand-saffron/30"
              >
                Open constituency card
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
