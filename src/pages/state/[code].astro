---
import StateMapExperience from "../../components/Map/StateMapExperience.tsx";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getSeedState,
  getStateElectionStatus,
  getStateNavigation,
  listStateNavigationRecords,
} from "../../lib/data";
import { toConstituencyPath, toStateCode, withBase } from "../../lib/routing";
import { buildConstituencyPanels } from "../../lib/view-models";

export function getStaticPaths() {
  return listStateNavigationRecords()
    .filter((state) => state.has_assembly)
    .map((state) => ({
      params: { code: state.code.toLowerCase() },
    }));
}

const baseUrl = import.meta.env.BASE_URL;
const code = toStateCode(Astro.params.code ?? "tn");
const state = getStateNavigation(code);
if (!state) {
  throw new Error(`Unknown state route: ${code}`);
}
const seedState = getSeedState(code);
const electionStatus = getStateElectionStatus(code);
const panels =
  state.state_route_mode === "map" ? buildConstituencyPanels(code) : [];
const geometryPath = `${baseUrl}data/geo/optimized/${code.toLowerCase()}-assembly.topojson`;
const statusLabel =
  electionStatus?.status_label ?? "Awaiting official ECI schedule.";
---

<BaseLayout
  title={`${state.name} | Political Report Card`}
  description={`State drilldown for ${state.name}.`}
>
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="grid gap-6 lg:grid-cols-[0.85fr_1.15fr]">
      <aside class="editorial-panel">
        <p class="eyebrow">State drilldown</p>
        <h1 class="panel-title" tabindex="-1" data-route-heading="true">
          {state.name}
        </h1>
        <p class="panel-copy">{statusLabel}</p>

        <div class="detail-grid">
          <div class="detail-card">
            <dt>Route mode</dt>
            <dd>{state.state_route_mode === "map" ? "Mapped" : "Shell"}</dd>
          </div>
          <div class="detail-card">
            <dt>Seeded seats</dt>
            <dd>{seedState?.seed_constituency_ids.length ?? 0}</dd>
          </div>
          <div class="detail-card">
            <dt>Mapped seats</dt>
            <dd>{panels.length || "Coming soon"}</dd>
          </div>
          <div class="detail-card">
            <dt>Storage model</dt>
            <dd>Static JSON only</dd>
          </div>
        </div>

        <div class="mt-6 space-y-3">
          <p class="eyebrow">Seed overlay</p>
          {
            seedState ? (
              seedState.seed_constituency_ids.map((id) => (
                <a
                  href={withBase(baseUrl, toConstituencyPath(id))}
                  class="shell-card block"
                >
                  <p class="font-semibold">{id.toLowerCase()}</p>
                  <p class="shell-copy">
                    Seed constituency page and MLA overlay.
                  </p>
                </a>
              ))
            ) : (
              <div class="shell-card">
                <p class="font-semibold">Candidate overlay pending</p>
                <p class="shell-copy">
                  This state route is live at the geometry layer, but it does
                  not yet ship seeded MLA or candidate JSON.
                </p>
              </div>
            )
          }
        </div>
      </aside>

      <div class="space-y-4">
        {
          state.state_route_mode === "map" ? (
            <StateMapExperience
              client:load
              basePath={baseUrl}
              geometryPath={geometryPath}
              stateCode={state.code}
              stateName={state.name}
              statusLabel={statusLabel}
              mode="browse"
              panels={panels}
            />
          ) : (
            <div class="editorial-panel">
              <p class="eyebrow">Constituency map coming soon</p>
              <h2 class="panel-title">
                This route is live before the polygons are.
              </h2>
              <p class="panel-copy">
                The national map already links here because the assembly route
                is canonical, but the constituency geometry bundle is still
                limited to Tamil Nadu and West Bengal in this MVP.
              </p>
            </div>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>
