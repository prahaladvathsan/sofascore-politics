---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Parties | Political Report Card"
  description="Reserved party directory route for later phases."
>
  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
    <div
      class="rounded-[2rem] border border-dashed border-brand-ink/15 bg-white/80 p-8 text-brand-slate shadow-card"
    >
      <p class="text-sm uppercase tracking-[0.18em] text-brand-saffron">
        Reserved route
      </p>
      <h1 class="mt-3 text-3xl font-semibold text-brand-ink">
        Party directory lands in a later phase.
      </h1>
      <p class="mt-3">
        The repo scaffold already includes static party JSON under <code
          >/data/parties</code
        >; this route is reserved for a richer directory once the broader state
        and constituency dataset expands.
      </p>
    </div>
  </section>
</BaseLayout>
