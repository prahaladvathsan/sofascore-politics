---
import StateMapExperience from "../../components/Map/StateMapExperience.tsx";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getConstituencyMapRecordBySlug,
  getStateElectionStatus,
  getStateNavigation,
  listConstituencyMapRecords,
} from "../../lib/data";
import { toConstituencySlug, toStatePath, withBase } from "../../lib/routing";
import { buildConstituencyPanels } from "../../lib/view-models";

export function getStaticPaths() {
  return listConstituencyMapRecords().map((record) => ({
    params: { id: record.slug },
  }));
}

const baseUrl = import.meta.env.BASE_URL;
const slug = toConstituencySlug(Astro.params.id ?? "tn-177");
const mapRecord = getConstituencyMapRecordBySlug(slug);
if (!mapRecord) {
  throw new Error(`Unknown constituency route: ${slug}`);
}
const panels = buildConstituencyPanels(mapRecord.state_code);
const panel = panels.find((candidate) => candidate.slug === slug);
if (!panel) {
  throw new Error(`No panel data found for constituency: ${slug}`);
}
const state = getStateNavigation(mapRecord.state_code);
if (!state) {
  throw new Error(`Unknown state for constituency: ${mapRecord.state_code}`);
}
const electionStatus = getStateElectionStatus(mapRecord.state_code);
---

<BaseLayout
  title={`${panel.name} | Political Report Card`}
  description={`Constituency drilldown for ${panel.name}, ${state.name}.`}
>
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="mb-8 grid gap-6 lg:grid-cols-[0.85fr_1.15fr]">
      <div class="editorial-panel">
        <p class="eyebrow">Constituency drilldown</p>
        <h1 class="panel-title" tabindex="-1" data-route-heading="true">
          Seat {panel.number}: {panel.name}
        </h1>
        <p class="panel-copy">
          {
            panel.hasSeedData
              ? "This seat combines the geometry-backed route with the seeded incumbent overlay."
              : "This seat already has a canonical constituency route, even though candidate enrichment is still pending."
          }
        </p>
      </div>
      <div class="editorial-panel">
        <p class="eyebrow">State context</p>
        <h2 class="panel-title">{state.name}</h2>
        <p class="panel-copy">
          {electionStatus?.status_label ?? "Awaiting official ECI schedule."}
        </p>
      </div>
    </div>

    <StateMapExperience
      client:load
      basePath={baseUrl}
      geometryPath={`${baseUrl}data/geo/optimized/${state.code.toLowerCase()}-assembly.topojson`}
      stateCode={state.code}
      stateName={state.name}
      statusLabel={electionStatus?.status_label ??
        "Awaiting official ECI schedule."}
      mode="focus"
      selectedSlug={panel.slug}
      panels={panels}
    />

    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href={withBase(baseUrl, toStatePath(state.code))}
        class="map-frame__legend-chip"
      >
        Back to state page
      </a>
      <a href={baseUrl} class="map-frame__legend-chip"> Back to homepage </a>
    </div>
  </section>
</BaseLayout>
