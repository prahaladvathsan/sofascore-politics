---
interface Props {
  to: string;
  title?: string;
}

const { to, title = "Redirecting..." } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0;url=${to}`} />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={to} />
    <title>{title}</title>
    <script is:inline define:vars={{ to }}>
      window.location.replace(to);
    </script>
  </head>
  <body>
    <p>
      Redirecting to <a href={to}>{to}</a>.
    </p>
  </body>
</html>
