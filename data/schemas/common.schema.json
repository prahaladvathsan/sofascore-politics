{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://political-report-card.example/data/schemas/common.schema.json",
  "title": "Common Political Report Card Schema Fragments",
  "definitions": {
    "sourceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "name", "retrieved_at"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sources"],
      "properties": {
        "source_note": {
          "type": "string"
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/sourceReference"
          }
        }
      }
    }
  }
}
