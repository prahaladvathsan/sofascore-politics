{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://political-report-card.example/data/schemas/party.schema.json",
  "title": "Party",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "short_name", "color", "official_url", "_meta"],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "short_name": {
      "type": "string"
    },
    "color": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "official_url": {
      "type": "string",
      "format": "uri"
    },
    "_meta": {
      "$ref": "common.schema.json#/definitions/meta"
    }
  }
}
