{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://political-report-card.example/data/schemas/manifesto-point.schema.json",
  "title": "ManifestoPoint",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "party_id", "category", "text", "status", "_meta"],
  "properties": {
    "id": {
      "type": "string"
    },
    "party_id": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "text": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["promised", "in_progress", "completed", "unclear"]
    },
    "_meta": {
      "$ref": "common.schema.json#/definitions/meta"
    }
  }
}
