{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://political-report-card.example/data/schemas/state-navigation.schema.json",
  "title": "State Navigation Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "code",
    "name",
    "type",
    "has_assembly",
    "state_route_mode",
    "theme",
    "_meta"
  ],
  "properties": {
    "code": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["state", "union_territory"]
    },
    "has_assembly": {
      "type": "boolean"
    },
    "state_route_mode": {
      "type": "string",
      "enum": ["map", "shell", "not_applicable"]
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "accent"],
      "properties": {
        "primary": {
          "type": "string",
          "pattern": "^#"
        },
        "accent": {
          "type": "string",
          "pattern": "^#"
        }
      }
    },
    "_meta": {
      "$ref": "./common.schema.json#/definitions/meta"
    }
  }
}
